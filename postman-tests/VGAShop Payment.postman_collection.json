        {
          "name": "VNPay Callback - Success",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const params = {",
                  "  vnp_Version: '2.1.0',",
                  "  vnp_Command: 'pay',",
                  "  vnp_TmnCode: pm.environment.get('vnp_TmnCode') || 'TMNCODE',",
                  "  vnp_Amount: '100000',",
                  "  vnp_CurrCode: 'VND',",
                  "  vnp_TxnRef: pm.environment.get('vnpayTransactionCode') || 'TXN123',",
                  "  vnp_OrderInfo: 'Payment for order',",
                  "  vnp_OrderType: 'other',",
                  "  vnp_Locale: 'vn',",
                  "  vnp_ReturnUrl: pm.environment.get('vnpReturnUrl') || 'http://localhost:8080',",
                  "  vnp_IpAddr: '127.0.0.1'",
                  "};",
                  "const keys = Object.keys(params).sort();",
                  "const hashData = keys.map(k => k + '=' + params[k]).join('&');",
                  "const secret = pm.environment.get('vnpayHashSecret') || 'SECRET';",
                  "const hash = CryptoJS.HmacSHA512(hashData, secret).toString();",
                  "const query = keys.map(k => encodeURIComponent(k) + '=' + encodeURIComponent(params[k])).join('&') + '&vnp_SecureHash=' + hash;",
                  "pm.environment.set('vnpSuccessQuery', query);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Payment successful response', function () { pm.expect(json.success).to.be.true; pm.expect(json.data).to.eql('OK'); });"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
