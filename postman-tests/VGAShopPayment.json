              ],
              "path": [
                "payments",
                "vnpay",
                "callback?vnp_ResponseCode=00&vnp_TxnRef=INVALID&vnp_SecureHash=BADHASH"
              ],
              "query": [
                {
                  "key": "vnp_ResponseCode",
                  "value": "00"
