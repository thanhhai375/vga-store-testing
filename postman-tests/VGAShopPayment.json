                "register"
              ],
              "query": [],
              "variable": []
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{$randomEmail}}\",\n  \"username\": \"{{$randomUserName}}\",\n  \"password\": \"123456\",\n  \"fullName\": \"Người Dùng Test\"\n}\n",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "packages": {},
                "requests": {},
                "exec": [
                  "var randomNum = Date.now();",
                  "",
                  "var randomEmail = \"test\" + randomNum + \"@gmail.com\";",
                  "var randomUsername = \"user\" + randomNum;",
                  "",
                  "pm.variables.set(\"randomEmail\", randomEmail);",
                  "pm.variables.set(\"randomUsername\", randomUsername);",
                  "",
                  "// Parse request body để lấy username vừa gửi",
                  "const requestBody = pm.request.body;",
                  "",
                  "// Lưu vào biến môi trường",
                  "pm.environment.set(\"loginUsername\", requestBody.username);"
                ]
              }
            }
          ]
        },
        {
