    {
      "name": "Auth",
      "item": [
        {
          "name": "Đăng ký",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var randomNum = Date.now();\r",
                  "\r",
                  "var randomEmail = \"test\" + randomNum + \"@gmail.com\";\r",
                  "var randomUsername = \"user\" + randomNum;\r",
                  "\r",
                  "pm.variables.set(\"randomEmail\", randomEmail);\r",
                  "pm.variables.set(\"randomUsername\", randomUsername);\r",
                  "\r",
                  "\r",
                  "// Parse request body để lấy username vừa gửi\r",
                  "const requestBody = JSON.parse(pm.request.body.raw);\r",
                  "\r",
                  "// Lưu vào biến môi trường\r",
                  "pm.environment.set(\"loginUsername\", requestBody.username);\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"email\": \"{{$randomEmail}}\",\r\n  \"username\": \"{{$randomUserName}}\",\r\n  \"password\": \"123456\",\r\n  \"fullName\": \"Người Dùng Test\"\r\n}\r\n"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Đăng nhập",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// const r = pm.response.json();\r",
                  "//  if(r.token) pm.collectionVariables.set('token', r.token);\r",
                  "\r",
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });\r",
                  "const json = pm.response.json();\r",
                  "pm.test('Login returned token', function () { pm.expect(json.token).to.be.a('string').that.is.not.empty; });\r",
                  "if (json.token) { pm.environment.set('token', json.token); }"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n \"username\": \"{{loginUsername}}\",\n  \"password\": \"123456\"\n}"
            },
