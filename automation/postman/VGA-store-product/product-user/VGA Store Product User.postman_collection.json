          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Đăng nhập thành công - Status code là 200', function () {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "pm.test('Thời gian phản hồi tốt (Dưới 2000ms)', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "pm.test('Trả về token Admin và lưu thành công', function () {",
                  "    var res = pm.response.json();",
                  "    pm.expect(res).to.have.property('token');",
                  "    pm.expect(res.role).to.equal('ADMIN');",
                  "    if (res.token) {",
                  "        pm.environment.set('adminToken', res.token);",
                  "        console.log('Admin [' + res.role + '] token saved');",
                  "    }",
                  "});"
                ],
