              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"TC_PROD_011 - Tìm kiếm sản phẩm theo tên hợp lệ thành công\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "    const responseData = pm.response.json();\r",
                  "    pm.expect(responseData.success).to.eql(true);\r",
                  "    \r",
                  "    const productsArray = responseData.data.content;\r",
                  "    pm.expect(productsArray).to.be.an('array');\r",
                  "    \r",
                  "    // Đảm bảo kết quả trả về có chứa sản phẩm khớp từ khóa\r",
                  "    if (productsArray.length > 0) {\r",
                  "        pm.expect(productsArray[0].name.toLowerCase()).to.include('asus');\r",
                  "    }\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC_PROD_013 - Tìm kiếm với ký tự đặc biệt không bị sập server\", function () {\r",
                  "    // Đảm bảo server không trả về lỗi 500\r",
                  "    pm.expect(pm.response.code).to.not.eql(500);\r",
                  "});"
