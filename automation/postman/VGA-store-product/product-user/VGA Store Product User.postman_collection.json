                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has token', function () {",
                  "    pm.expect(jsonData.token).to.not.be.undefined;",
                  "});",
                  "pm.test('Registration successful', function () {",
                  "    pm.expect(jsonData.message).to.eql('Registration successful');",
                  "});",
                  "pm.test('Response has username and userId', function () {",
                  "    pm.expect(jsonData.username).to.not.be.undefined;",
                  "    pm.expect(jsonData.userId).to.not.be.undefined;",
                  "});",
                  "// Lưu thông tin user thường để Đăng nhập User dùng",
                  "pm.environment.set('loginUsername', jsonData.username);",
                  "pm.environment.set('loginPassword', '123456');",
                  "pm.environment.set('userId', jsonData.userId);",
                  "console.log('Saved loginUsername = ' + jsonData.username);"
