      "name": "Auth",
      "item": [
        {
          "name": "Đăng ký Admin",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var uniqueNum = Date.now();",
                  "var randomUsername = 'admin_' + uniqueNum;",
                  "var randomEmail = 'admin_' + uniqueNum + '@test.com';",
                  "pm.environment.set('adminUsername', randomUsername);",
                  "pm.environment.set('adminPassword', '123456');",
                  "pm.variables.set('random_username', randomUsername);",
                  "pm.variables.set('random_email', randomEmail);",
                  "console.log('Tạo admin: ' + randomUsername);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Đăng ký thành công - Status code là 200 hoặc 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test('Thời gian phản hồi nhanh (Dưới 2000ms)', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "pm.test('Kiểm tra cấu trúc dữ liệu trả về', function () {",
                  "    pm.expect(pm.response.json()).to.be.an('object');",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"123456\",\n  \"email\": \"{{random_email}}\",\n  \"fullName\": \"Super Admin Test\",\n  \"role\": \"ADMIN\"\n}"
            },
