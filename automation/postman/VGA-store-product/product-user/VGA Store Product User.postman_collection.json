                "exec": [
                  "pm.test(\"TC_PROD_015 - Lọc sản phẩm theo khoảng giá và danh mục thành công\", function () {\r",
                  "    // 1. Kiểm tra Status Code trả về phải là 200 OK\r",
                  "    pm.response.to.have.status(200);\r",
                  "    \r",
                  "    // 2. Ép kiểu dữ liệu trả về sang JSON\r",
                  "    const responseData = pm.response.json();\r",
                  "    pm.expect(responseData.success).to.eql(true);\r",
                  "    \r",
                  "    // 3. Lấy mảng danh sách sản phẩm từ data.content của bạn\r",
                  "    const productsArray = responseData.data.content;\r",
                  "    pm.expect(productsArray).to.be.an('array');\r",
                  "    \r",
                  "    // 4. Nếu có sản phẩm trả về, kiểm tra xem giá của nó có nằm đúng trong khoảng lọc không\r",
                  "    if (productsArray.length > 0) {\r",
                  "        const firstProductPrice = productsArray[0].price;\r",
                  "        pm.expect(firstProductPrice).to.be.at.least(1000000); // Lớn hơn hoặc bằng minPrice\r",
                  "        pm.expect(firstProductPrice).to.be.at.most(50000000); // Nhỏ hơn hoặc bằng maxPrice\r",
                  "    }\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC_PROD_017 - Hệ thống phản hồi nhanh khi thực hiện lọc dữ liệu\", function () {\r",
