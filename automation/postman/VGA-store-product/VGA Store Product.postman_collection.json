        {
          "name": "Đăng nhập",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Kiểm tra xem Server có phản hồi thành công không (Mã 200 OK)\r",
                  "pm.test(\"Đăng nhập thành công - Status code là 200\", function () {\r",
                  "    pm.expect(pm.response.code).to.equal(200);\r",
                  "});\r",
                  "\r",
                  "// 2. Kiểm tra thời gian phản hồi của Server\r",
                  "pm.test(\"Thời gian phản hồi tốt (Dưới 2000ms)\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  "// 3. Phân tích kết quả JSON để lấy dữ liệu kiểm tra và lưu Token\r",
                  "pm.test(\"Trả về đúng cấu trúc dữ liệu và lưu Token thành công\", function () {\r",
                  "    const res = pm.response.json();\r",
                  "    \r",
                  "    // Đảm bảo dữ liệu trả về là một object hợp lệ\r",
                  "    pm.expect(res).to.be.an('object');\r",
                  "    \r",
                  "    // Kiểm tra xem server có trả về token không\r",
                  "    pm.expect(res).to.have.property('token'); \r",
                  "    // Nếu object token nằm sâu hơn (ví dụ: res.data.token), bạn sửa lại thành:\r",
                  "    // pm.expect(res.data).to.have.property('token');\r",
                  "\r",
                  "    // Lưu token vào biến Collection (giống như logic cũ của bạn nhưng tường minh hơn)\r",
                  "    if (res.token) {\r",
                  "        pm.collectionVariables.set('token', res.token);\r",
                  "        console.log(\"Đã lưu token mới vào Collection: \" + res.token);\r",
                  "    }\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
