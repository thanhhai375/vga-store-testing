        {
          "name": "Đăng ký Admin",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Tạo một số ngẫu nhiên dựa trên thời gian hiện tại để không bị trùng username/email\r",
                  "const uniqueNumber = Date.now();\r",
                  "\r",
                  "const randomUsername = `admin_${uniqueNumber}`;\r",
                  "const randomEmail = `admin_${uniqueNumber}@gmail.com`;\r",
                  "\r",
                  "// Lưu vào biến môi trường tạm thời (Variables) của Postman\r",
                  "pm.variables.set(\"random_username\", randomUsername);\r",
                  "pm.variables.set(\"random_email\", randomEmail);\r",
                  "\r",
                  "console.log(\"Đã tạo Username ngẫu nhiên: \" + randomUsername);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Check xem API có đăng ký thành công (Status 200 hoặc 201) không\r",
                  "pm.test(\"Đăng ký thành công - Status code là 200 hoặc 201\", function () {\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);\r",
                  "});\r",
                  "\r",
                  "// 2. Check thời gian phản hồi của Server\r",
                  "pm.test(\"Thời gian phản hồi nhanh (Dưới 2000ms)\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  "// 3. Phân tích cú pháp JSON để kiểm tra chi tiết dữ liệu trả về\r",
                  "pm.test(\"Kiểm tra cấu trúc dữ liệu trả về\", function () {\r",
                  "    const responseData = pm.response.json();\r",
                  "    \r",
                  "    // Đảm bảo kết quả trả về có chứa thông tin user hoặc thông báo thành công\r",
                  "    // Bạn có thể chỉnh sửa lại key ('message', 'data', 'user'...) cho đúng với API của bạn\r",
                  "    pm.expect(responseData).to.be.an('object'); \r",
                  "    \r",
                  "    // Ví dụ: kiểm tra xem response có báo success: true không (nếu API của bạn có cấu trúc này)\r",
                  "    // pm.expect(responseData.success).to.be.true;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin_{{$randomUserName}}\",\n  \"password\": \"123456\",\n  \"email\": \"admin_{{$randomEmail}}\",\n  \"fullName\": \"Super Admin {{$randomFullName}}\"\n}\n"
