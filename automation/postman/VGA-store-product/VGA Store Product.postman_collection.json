          "name": "Danh sách sản phẩm",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"TC_PROD_001 - Hiển thị danh sách VGA thành công\", function () {\r",
                  "    // Kiểm tra status trả về có phải là 200 OK và thuộc tính success là true không\r",
                  "    pm.response.to.have.status(200);\r",
                  "    const responseData = pm.response.json();\r",
                  "    pm.expect(responseData.success).to.eql(true);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC_PROD_002 -> 005 - Dữ liệu hiển thị đầy đủ thông tin\", function () {\r",
                  "    const responseData = pm.response.json();\r",
                  "    \r",
                  "    // Đã sửa đường dẫn: Bóc đúng vào mảng 'content' nằm trong 'data'\r",
                  "    const productsArray = responseData.data.content;\r",
                  "    \r",
                  "    // Kiểm tra cấu trúc mảng danh sách sản phẩm\r",
                  "    pm.expect(productsArray).to.be.an('array');\r",
                  "    \r",
                  "    if (productsArray.length > 0) {\r",
                  "        const product = productsArray[0];\r",
                  "        \r",
                  "        // Kiểm tra Tên sản phẩm (TC_PROD_002)\r",
                  "        pm.expect(product).to.have.property('name');  \r",
                  "        \r",
                  "        // Kiểm tra Định dạng giá sản phẩm (TC_PROD_004)\r",
                  "        pm.expect(product).to.have.property('price'); \r",
                  "        pm.expect(product.price).to.be.a('number');\r",
                  "        \r",
                  "        // Đã sửa: Kiểm tra đường dẫn Ảnh chuẩn (TC_PROD_003)\r",
                  "        pm.expect(product).to.have.property('imgUrl'); \r",
                  "        \r",
                  "        // Kiểm tra xem sản phẩm có đối tượng Brand (Hãng) đi kèm không (TC_PROD_005)\r",
                  "        pm.expect(product).to.have.property('brand');\r",
                  "        pm.expect(product.brand).to.have.property('name');\r",
                  "    }\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
