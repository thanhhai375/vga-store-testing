                  "    pm.expect(productsArray).to.be.an('array');\r",
                  "    \r",
                  "    // 4. Nếu có sản phẩm trả về, kiểm tra xem giá của nó có nằm đúng trong khoảng lọc không\r",
                  "    if (productsArray.length > 0) {\r",
                  "        const firstProductPrice = productsArray[0].price;\r",
                  "        pm.expect(firstProductPrice).to.be.at.least(1000000); // Lớn hơn hoặc bằng minPrice\r",
