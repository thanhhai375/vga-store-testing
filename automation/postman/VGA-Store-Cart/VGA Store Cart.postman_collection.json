      "item": [
        {
          "name": "Đăng ký",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has token\", function () {\r",
                  "    pm.expect(jsonData.token).to.not.be.undefined;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Registration successful\", function () {\r",
                  "    pm.expect(jsonData.message).to.eql(\"Registration successful\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has username and userId\", function () {\r",
                  "    pm.expect(jsonData.username).to.not.be.undefined;\r",
                  "    pm.expect(jsonData.userId).to.not.be.undefined;\r",
                  "});\r",
                  "\r",
                  "// Lưu vào Environment để Login dùng\r",
                  "pm.environment.set(\"loginUsername\", jsonData.username);\r",
                  "pm.environment.set(\"token\", jsonData.token);\r",
                  "pm.environment.set(\"userId\", jsonData.userId);\r",
                  "\r",
                  "console.log(\"Saved loginUsername = \" + jsonData.username);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
