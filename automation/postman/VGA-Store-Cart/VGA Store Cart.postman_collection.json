        {
          "name": "TC_CART_01_02_03_04_05_06_07_20 - Thêm sản phẩm vào giỏ hàng",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const statusCode = pm.response.code;\r",
                  "const res = pm.response.json();\r",
                  "\r",
                  "\r",
                  "pm.test(\"TC_CART_01 - Thêm sản phẩm vào giỏ hàng thành công\", function () {\r",
                  "    pm.expect(statusCode).to.be.oneOf([200, 201]);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC_CART_02 - Thêm sản phẩm với số lượng hợp lệ thành công\", function () {\r",
                  "    pm.expect(statusCode).to.be.oneOf([200, 201]);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC_CART_03 - Hệ thống bắt lỗi khi số lượng vượt tồn kho (Bỏ qua nếu đang chạy luồng Đúng)\", function () {\r",
                  "    if (statusCode === 400 || statusCode === 422) { pm.expect(res.message).to.be.a('string'); }\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC_CART_04 - Hệ thống bắt lỗi khi productId trống (Bỏ qua nếu đang chạy luồng Đúng)\", function () {\r",
                  "    if (statusCode === 400 || statusCode === 422) { pm.expect(res.message).to.be.a('string'); }\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC_CART_05 - Hệ thống bắt lỗi khi số lượng bằng 0 (Bỏ qua nếu đang chạy luồng Đúng)\", function () {\r",
                  "    if (statusCode === 400 || statusCode === 422) { pm.expect(res.message).to.be.a('string'); }\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC_CART_06 - Hệ thống bắt lỗi khi số lượng là số âm (Bỏ qua nếu đang chạy luồng Đúng)\", function () {\r",
                  "    if (statusCode === 400 || statusCode === 422) { pm.expect(res.message).to.be.a('string'); }\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC_CART_07 - Hệ thống bắt lỗi khi productId không tồn tại (Bỏ qua nếu đang chạy luồng Đúng)\", function () {\r",
                  "    if (statusCode === 404) { pm.expect(statusCode).to.eql(404); }\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC_CART_20 - Hệ thống trả về cấu trúc giỏ hàng và thông báo hợp lệ\", function () {\r",
                  "    pm.expect(res).to.have.property(\"message\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"BUG-003 - Kiểm tra tổng tiền chính xác (không bị cộng phí ảo)\", function () {\r",
                  "    const cartData = res.data || res;\r",
                  "    if (cartData && cartData.items) {\r",
                  "        let expectedTotal = cartData.items.reduce((sum, item) => sum + (item.price * item.quantity), 0);\r",
                  "        pm.expect(cartData.totalAmount).to.eql(expectedTotal);\r",
                  "    }\r",
                  "});\r",
                  "\r",
                  "// Tự động bóc tách và lưu cartItemId cho các bước sau\r",
                  "const cartData = res.data || res;\r",
                  "if ((statusCode === 200 || statusCode === 201) && cartData && cartData.items && cartData.items.length > 0) {\r",
                  "    pm.environment.set(\"cartItemId\", cartData.items[0].cartItemId);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
