        {
          "name": "TC_CART_08_09 - Lấy dữ liệu danh sách giỏ hàng",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();\r",
                  "const cartData = res.data || res;\r",
                  "\r",
                  "pm.test(\"TC_CART_08 - Kiểm tra hiển thị thông tin khi giỏ hàng rỗng (Bỏ qua nếu giỏ có đồ)\", function () {\r",
                  "    if (cartData.totalItems === 0) {\r",
                  "        pm.expect(cartData.totalAmount).to.eql(0);\r",
                  "    }\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC_CART_09 - Hiển thị danh sách sản phẩm trong giỏ hàng thành công\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "    if (cartData.items) { pm.expect(cartData.items).to.be.an('array'); }\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "GET",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"productId\": 1,\r\n  \"quantity\": 1\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
