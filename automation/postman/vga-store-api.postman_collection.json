{
	"info": {
		"name": "VGA Store API Tests",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth Module",
			"item": [
				{
					"name": "Đăng nhập sai tài khoản (Fail test)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// KỊCH BẢN TEST CỦA POSTMAN NẰM Ở ĐÂY",
									"pm.test(\"Kiểm tra mã trạng thái phải là 400 (Bad Request)\", function () {",
									"    pm.response.to.have.status(400);",
									"});",
									"",
									"pm.test(\"Kiểm tra nội dung trả về phải báo lỗi Invalid username\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.message).to.include(\"Invalid username or password\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"taikhoansai\",\n    \"password\": \"123456\"\n}"
						},
						"url": {
							"raw": "http://localhost:8080/api/auth/login",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8080",
							"path": [
								"api",
								"auth",
								"login"
							]
						}
					},
					"response": []
				}
			]
		}
	]
}
