              "    default:\r",
              "        pm.test(\" Hàng dữ liệu chứa TestId lạ: \" + testId, function() {\r",
              "            pm.expect(true).to.be.true;\r",
              "        });\r",
              "        break;\r",
              "}\r",
              "\r",
              "console.log(\" Test \" + testId + \" completed\\n\");"
