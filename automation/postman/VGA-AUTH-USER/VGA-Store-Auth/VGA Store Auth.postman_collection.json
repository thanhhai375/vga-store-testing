  "item": [
    {
      "name": "Register",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "function getExpectedStatus() {",
              "    var raw = pm.variables.get(\"expectedStatus\") || pm.iterationData.get(\"expectedStatus\");",
              "    if (!raw) return null;",
              "    var parsed = parseInt(String(raw).trim(), 10);",
              "    return Number.isNaN(parsed) ? null : parsed;",
              "}",
              "",
              "function getExpectedMessage() {",
              "    return String(pm.variables.get(\"expectedMessage\") || pm.iterationData.get(\"expectedMessage\") || \"\").trim();",
              "}",
              "",
              "function parseJsonSafely() {",
              "    try { return pm.response.json(); } catch (e) { return {}; }",
              "}",
              "",
              "function collectResponseText(jsonData) {",
              "    var parts = [];",
              "    if (jsonData.message) parts.push(jsonData.message);",
              "    if (jsonData.error) parts.push(jsonData.error);",
              "    if (jsonData.data && typeof jsonData.data === \"object\") parts.push(Object.values(jsonData.data).join(\" \"));",
              "    if (typeof jsonData.data === \"string\") parts.push(jsonData.data);",
              "    parts.push(pm.response.text());",
              "    return parts.join(\" \").toLowerCase();",
              "}",
              "",
              "function extractToken(jsonData) {",
              "    return jsonData.token || (jsonData.data && jsonData.data.token);",
              "}",
              "",
              "function assertExpectedStatus() {",
              "    var expectedStatus = getExpectedStatus();",
              "    if (expectedStatus !== null) {",
              "        pm.test(\"Expected HTTP status \" + expectedStatus, function () {",
              "            pm.expect(pm.response.code).to.eql(expectedStatus);",
              "        });",
              "    }",
              "}",
              "",
              "function assertExpectedMessageOrToken(jsonData) {",
              "    var expectedMessage = getExpectedMessage();",
              "    if (!expectedMessage) return;",
              "",
              "    if (expectedMessage.toLowerCase() === \"token\") {",
              "        pm.test(\"Response contains auth token\", function () {",
              "            pm.expect(extractToken(jsonData)).to.exist;",
              "        });",
              "        return;",
              "    }",
              "",
              "    if (expectedMessage.toLowerCase() === \"validation\") {",
              "        pm.test(\"Response contains validation error details\", function () {",
              "            pm.expect(collectResponseText(jsonData)).to.not.equal(\"\");",
              "        });",
              "        return;",
              "    }",
              "",
              "    pm.test(\"Response contains expected message: \" + expectedMessage, function () {",
              "        pm.expect(collectResponseText(jsonData)).to.include(expectedMessage.toLowerCase());",
              "    });",
              "}",
              "",
              "var testType = pm.variables.get(\"testType\");",
              "var testId = pm.variables.get(\"testId\");",
              "",
              "if (testType && testType !== \"REGISTER\") {",
              "    console.log(\"[Skip Test] Row is for \" + testType + \", not REGISTER.\");",
              "    return;",
              "}",
              "",
              "var jsonData = parseJsonSafely();",
              "assertExpectedStatus();",
              "assertExpectedMessageOrToken(jsonData);",
              "",
              "if (pm.response.code >= 200 && pm.response.code < 300) {",
              "    pm.test(\"Registered user matches submitted username/email\", function () {",
              "        var user = jsonData.data || jsonData;",
              "        var expectedUsername = pm.variables.get(\"effectiveRegisterUsername\") || pm.variables.get(\"username\");",
              "        var expectedEmail = pm.variables.get(\"effectiveRegisterEmail\") || pm.variables.get(\"email\");",
              "        if (expectedUsername) pm.expect(user.username).to.eql(expectedUsername);",
              "        if (expectedEmail) pm.expect(user.email).to.eql(expectedEmail);",
              "    });",
              "",
              "    var savedToken = extractToken(jsonData);",
              "    if (savedToken) pm.environment.set(\"authToken\", savedToken);",
              "}",
              "",
              "console.log(\"REGISTER \" + testId + \" completed with status \" + pm.response.code);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "var testType = pm.variables.get(\"testType\");",
              "var testId = pm.variables.get(\"testId\");",
              "",
              "if (testType && testType !== \"REGISTER\") {",
              "    pm.execution.skipRequest();",
              "}",
              "",
              "var username = pm.variables.get(\"username\");",
              "var email = pm.variables.get(\"email\");",
              "var password = pm.variables.get(\"password\");",
              "var fullName = pm.variables.get(\"fullName\");",
              "",
              "var uniqueSuffix = Date.now().toString(36).slice(-6) + pm.info.iteration;",
              "var positiveRegisterIds = [\"R-001\", \"R-007\", \"R-009\", \"R-015\", \"R-016\"];",
              "",
              "if (positiveRegisterIds.includes(testId)) {",
              "    if (testId === \"R-007\") {",
              "        username = Date.now().toString(36).slice(-3);",
              "    } else if (testId === \"R-009\") {",
              "        username = (username || \"r009_user\").substring(0, 50 - uniqueSuffix.length) + uniqueSuffix;",
              "    } else {",
              "        username = (username || testId.toLowerCase().replace(\"-\", \"\")) + \"_\" + uniqueSuffix;",
              "    }",
              "}",
              "",
              "var duplicateEmailIds = [\"R-012\", \"R-013\"];",
              "if (!duplicateEmailIds.includes(testId) && email && email.includes(\"@\")) {",
              "    var leadingWhitespace = email.match(/^\\s*/)[0];",
              "    var trailingWhitespace = email.match(/\\s*$/)[0];",
              "    var trimmedEmail = email.trim();",
              "    var emailParts = trimmedEmail.split(\"@\");",
              "    email = leadingWhitespace + emailParts[0] + \"+\" + uniqueSuffix + \"@\" + emailParts[1] + trailingWhitespace;",
              "}",
              "",
              "if (testId === \"R-013\" && pm.environment.get(\"tempRegisterEmail\")) {",
              "    email = pm.environment.get(\"tempRegisterEmail\");",
              "}",
              "",
              "var body = {",
              "    username: username || \"\",",
              "    email: email || \"\",",
              "    password: password || \"\",",
              "    fullName: fullName || \"\"",
              "};",
              "",
              "pm.variables.set(\"effectiveRegisterUsername\", body.username);",
              "pm.variables.set(\"effectiveRegisterEmail\", body.email);",
              "pm.request.body.raw = JSON.stringify(body);",
              "",
              "if (testId === \"R-001\") {",
              "    pm.environment.set(\"tempRegisterUsername\", body.username);",
              "    pm.environment.set(\"tempRegisterEmail\", body.email);",
              "    pm.environment.set(\"tempRegisterPassword\", body.password);",
              "}",
              "",
              "console.log(\"REGISTER \" + testId + \" body:\", pm.request.body.raw);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      },
      "response": []
