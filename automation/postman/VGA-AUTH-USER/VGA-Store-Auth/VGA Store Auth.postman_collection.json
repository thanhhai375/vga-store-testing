  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "// 1. Lấy kiểu test của dòng hiện tại trong file CSV (LOGIN, REGISTER, CHANGE_PWD, GOOGLE_LOGIN)\r",
          "let csvTestType = pm.iterationData.get(\"testType\");\r",
          "\r",
          "// 2. Lấy tên API đang chạy hiện tại trong Postman (ví dụ: \"Register\", \"Login\"...)\r",
          "let currentApiName = pm.info.requestName;\r",
          "\r",
          "// Chuẩn hóa tên để so sánh không phân biệt hoa thường hoặc khoảng cách\r",
          "if (csvTestType && currentApiName) {\r",
          "    let normalizedApiName = currentApiName.toLowerCase().replace(/\\s+/g, '');\r",
          "    let normalizedCsvType = csvTestType.toLowerCase().replace(/[^a-z0-9]/g, ''); // loại bỏ ký tự đặc biệt như dấu gạch dưới\r",
          "\r",
          "    // Điều chỉnh khớp luồng đặc thũ cho GOOGLE_LOGIN và CHANGE_PWD\r",
          "    if (normalizedApiName.includes(\"google\")) normalizedApiName = \"googlelogin\";\r",
          "    if (normalizedApiName.includes(\"change\")) normalizedApiName = \"changepwd\";\r",
          "\r",
          "    // Nếu dòng dữ liệu trong CSV không trùng khớp với API hiện tại thì bỏ qua dòng đó\r",
          "    if (!normalizedApiName.includes(normalizedCsvType) && !normalizedCsvType.includes(normalizedApiName)) {\r",
          "        pm.execution.skipRequest();\r",
          "    }\r",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          ""
        ]
      }
    }
  ]
