    {
      "name": "ChangePassword",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// =========================================\r",
              "// TEST SCRIPT: CHANGE PASSWORD - Post-response (Tests)\r",
              "// =========================================\r",
              "\r",
              "// 1. PHÂN LUỒNG DỮ LIỆU: Bỏ qua nếu dòng dữ liệu CSV thuộc về API khác\r",
              "var testType = pm.variables.get(\"testType\");\r",
              "var testId = pm.variables.get(\"testId\");\r",
              "\r",
              "if (testType && testType !== \"CHANGE_PASSWORD\") {\r",
              "    console.log(\" [Skip Test] Dòng này dành cho \" + testType + \", không phải CHANGE_PASSWORD.\");\r",
              "    return;\r",
              "}\r",
              "\r",
              "console.log(\"\\n═══════════════════════════════════════\");\r",
              "console.log(\" CHANGE PASSWORD RESPONSE - TestId: \" + testId);\r",
              "console.log(\" Status Code: \" + pm.response.code);\r",
              "console.log(\"═══════════════════════════════════════\");\r",
              "\r",
              "// 2. PARSE JSON AN TOÀN (Tránh sập script khi Server lỗi hoặc trả về HTML)\r",
              "var jsonData = {};\r",
              "var isJson = true;\r",
              "try {\r",
              "    jsonData = pm.response.json();\r",
              "} catch (e) {\r",
              "    isJson = false;\r",
              "}\r",
              "\r",
              "// Chuẩn hóa chuỗi báo lỗi sang chữ thường để kiểm tra linh hoạt hơn\r",
              "var errorMsg = isJson ? (jsonData.message || jsonData.error || \"\").toLowerCase() : \"\";\r",
              "// Gộp data field vào errorMsg để kiểm tra validation errors chi tiết",
              "if (isJson && jsonData.data && typeof jsonData.data === 'object') {",
              "    var dataValues = Object.values(jsonData.data).join(' ').toLowerCase();",
              "    errorMsg = errorMsg + ' ' + dataValues;",
              "}",
              "\r",
              "// 3. SWITCH-CASE THEO ĐÚNG MA TRẬN TESTID CỦA FILE CSV\r",
              "switch (testId) {\r",
              "\r",
              "    // ========== C-001: VALID CHANGE ==========\r",
              "    case \"C-001\":\r",
              "        pm.test(\" C-001: Status code phải là 200\", function() {\r",
              "            pm.response.to.have.status(200);\r",
              "        });\r",
              "        \r",
              "        pm.test(\" C-001: Phải có thông báo thành công\", function() {\r",
              "            var msg = (jsonData.message || jsonData.data || \"\").toLowerCase();\r",
              "            pm.expect(msg).to.include(\"thành công\");\r",
              "        });\r",
              "        break;\r",
              "\r",
              "    // ========== C-002: EMPTY OLD PASSWORD ==========\r",
              "    case \"C-002\":\r",
              "        pm.test(\" C-002: Status 400 hoặc lỗi Validation\", function() {\r",
              "            pm.expect(pm.response.code).to.be.oneOf([400, 422]);\r",
              "        });\r",
              "        pm.test(\" C-002: Message báo trống mật khẩu cũ\", function() {\r",
              "            pm.expect(errorMsg).to.satisfy(function(msg) {\r",
              "                return msg.includes(\"cũ\") || msg.includes(\"old\") || msg.includes(\"trống\") || msg.includes(\"required\");\r",
              "            });\r",
              "        });\r",
              "        break;\r",
              "\r",
              "    // ========== C-003: EMPTY NEW PASSWORD ==========\r",
              "    case \"C-003\":\r",
              "        pm.test(\" C-003: Status 400 hoặc lỗi Validation\", function() {\r",
              "            pm.expect(pm.response.code).to.be.oneOf([400, 422]);\r",
              "        });\r",
              "        pm.test(\" C-003: Message báo trống mật khẩu mới\", function() {\r",
              "            pm.expect(errorMsg).to.satisfy(function(msg) {\r",
              "                return msg.includes(\"mới\") || msg.includes(\"new\") || msg.includes(\"trống\") || msg.includes(\"required\");\r",
              "            });\r",
              "        });\r",
              "        break;\r",
              "\r",
              "    // ========== C-004: EMPTY CONFIRM PASSWORD ==========\r",
              "    case \"C-004\":\r",
              "        pm.test(\" C-004: Status 400 hoặc lỗi Validation\", function() {\r",
              "            pm.expect(pm.response.code).to.be.oneOf([400, 422]);\r",
              "        });\r",
              "        pm.test(\" C-004: Message báo trống mật khẩu xác nhận\", function() {\r",
              "            pm.expect(errorMsg).to.satisfy(function(msg) {\r",
              "                return msg.includes(\"xác nhận\") || msg.includes(\"confirm\") || msg.includes(\"trống\") || msg.includes(\"required\");\r",
              "            });\r",
              "        });\r",
              "        break;\r",
              "\r",
              "    // ========== C-005: WRONG OLD PASSWORD ==========\r",
              "    case \"C-005\":\r",
              "        pm.test(\" C-005: Status 400 (Mật khẩu cũ không chính xác)\", function() {\r",
              "            pm.response.to.have.status(400);\r",
              "        });\r",
              "        pm.test(\" C-005: Message báo sai mật khẩu cũ\", function() {\r",
              "            pm.expect(errorMsg).to.satisfy(function(msg) {\r",
              "                return msg.includes(\"sai\") || msg.includes(\"không đúng\") || msg.includes(\"invalid\") || msg.includes(\"old\");\r",
              "            });\r",
              "        });\r",
              "        break;\r",
              "\r",
              "    // ========== C-006: PASSWORD TOO SHORT ==========\r",
              "    case \"C-006\":\r",
              "        pm.test(\" C-006: Status 400 (Mật khẩu quá ngắn)\", function() {\r",
              "            pm.expect(pm.response.code).to.be.oneOf([400, 422]);\r",
              "        });\r",
              "        pm.test(\" C-006: Message cảnh báo độ dài tối thiểu (ví dụ: chứa số '6')\", function() {\r",
              "            pm.expect(errorMsg).to.satisfy(function(msg) {\r",
              "                return msg.includes(\"6\") || msg.includes(\"short\") || msg.includes(\"length\") || msg.includes(\"ký tự\");\r",
              "            });\r",
              "        });\r",
              "        break;\r",
              "\r",
              "    // ========== C-007: PASSWORD MIN VALID LENGTH ==========\r",
              "    // ========== C-008: PASSWORD VERY LONG ==========\r",
              "    case \"C-007\":\r",
              "    case \"C-008\":\r",
              "        pm.test(\" \" + testId + \": Đổi mật khẩu thành công với biên hợp lệ (Status 200)\", function() {\r",
              "            pm.response.to.have.status(200);\r",
              "        });\r",
              "        break;\r",
              "\r",
              "    // ========== C-009: CONFIRM NOT MATCHING ==========\r",
              "    case \"C-009\":\r",
              "        pm.test(\" C-009: Status 400 (Mật khẩu không trùng khớp)\", function() {\r",
              "            pm.expect(pm.response.code).to.be.oneOf([400, 422]);\r",
              "        });\r",
              "        pm.test(\" C-009: Message báo lỗi không khớp\", function() {\r",
              "            pm.expect(errorMsg).to.satisfy(function(msg) {\r",
              "                return msg.includes(\"khớp\") || msg.includes(\"match\") || msg.includes(\"confirm\");\r",
              "            });\r",
              "        });\r",
              "        break;\r",
              "\r",
              "    // ========== C-010: SAME AS OLD PASSWORD ==========\r",
              "    case \"C-010\":\r",
              "        pm.test(\" C-010: Status 400 (Mật khẩu mới trùng mật khẩu cũ)\", function() {\r",
              "            pm.response.to.have.status(400);\r",
              "        });\r",
              "        pm.test(\" C-010: Message báo lỗi trùng lặp\", function() {\r",
              "            pm.expect(errorMsg).to.satisfy(function(msg) {\r",
              "                return msg.includes(\"trùng\") || msg.includes(\"cũ\") || msg.includes(\"same\") || msg.includes(\"different\");\r",
              "            });\r",
              "        });\r",
              "        break;\r",
              "\r",
              "    // ========== C-011 to C-013: EDGE CASES (Ký tự đặc biệt, khoảng trắng...) ==========\r",
              "    case \"C-011\":\r",
              "    case \"C-012\":\r",
              "    case \"C-013\":\r",
              "        pm.test(\" \" + testId + \": Xử lý trường hợp biên (Chấp nhận 200 thành công hoặc 400 chặn lỗi định dạng)\", function() {\r",
              "            pm.expect(pm.response.code).to.be.oneOf([200, 400, 422]);\r",
