        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// 1. PHÂN LUỒNG DỮ LIỆU: Bỏ qua nếu dòng này thuộc về API khác\r",
              "var testType = pm.variables.get(\"testType\");\r",
              "var testId = pm.variables.get(\"testId\");\r",
              "\r",
              "if (testType && testType !== \"CHANGE_PWD\") {\r",
              "    pm.execution.skipRequest();\r",
              "}\r",
              "\r",
              "// 2. LẤY DỮ LIỆU TỪ CSV & ENVIRONMENT\r",
              "var oldPassword = pm.variables.get(\"oldPassword\");\r",
              "var newPassword = pm.variables.get(\"newPassword\");\r",
              "var confirmPassword = pm.variables.get(\"confirmPassword\");\r",
              "\r",
              "// Sử dụng biến authToken đồng bộ xuyên suốt từ các bước Register/Login trước\r",
              "var authToken = pm.environment.get(\"authToken\");\r",
              "\r",
              "console.log(\"═══════════════════════════════════════\");\r",
              "console.log(\" CHANGE PASSWORD TEST - [\" + (testId || \"N/A\") + \"]\");\r",
              "console.log(\"═══════════════════════════════════════\");\r",
              "\r",
              "// 3. XÂY DỰNG BODY REQUEST (Đảm bảo không bị lỗi undefined/null)\r",
              "var body = {\r",
              "    oldPassword: (oldPassword !== undefined && oldPassword !== null) ? oldPassword : \"\",\r",
              "    newPassword: (newPassword !== undefined && newPassword !== null) ? newPassword : \"\",\r",
              "    confirmPassword: (confirmPassword !== undefined && confirmPassword !== null) ? confirmPassword : \"\"\r",
              "};\r",
              "\r",
              "// Xử lý chuyển đổi chữ \"BLANK\" thành khoảng trống thực tế\r",
              "if (body.oldPassword === \"BLANK\") body.oldPassword = \"\";\r",
              "if (body.newPassword === \"BLANK\") body.newPassword = \"\";\r",
              "if (body.confirmPassword === \"BLANK\") body.confirmPassword = \"\";\r",
              "\r",
              "// Nạp Body vào Request dưới dạng JSON\r",
              "pm.request.body.raw = JSON.stringify(body);\r",
              "\r",
              "// LOGGING HỖ TRỢ DEBUG TRÊN CONSOLE\r",
              "console.log(\" 📤 Request Body (masked): old=****, new=****, confirm=****\");\r",
              "console.log(\" 🔑 Auth Token State: \" + (authToken ? \" AVAILABLE\" : \"❌ MISSING\"));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "// {\r\n//     \"oldPassword\":\"123456\",\r\n//     \"newPassword\":\"newpassword123\"\r\n// }\r\n\r\n{\"oldPassword\":\"{{oldPassword}}\",\r\n\"newPassword\":\"{{newPassword}}\"\r\n// \"comfirmPassword\":\"{{comfirmPassword}}\"\r\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/change-password",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "change-password"
          ]
        }
      },
      "response": []
    }
