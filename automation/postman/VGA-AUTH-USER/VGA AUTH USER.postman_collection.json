          "name": "TC_AUTH_01 - Đăng ký tài khoản thành công",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"TC_AUTH_01 - Status code là 200 hoặc 201\", function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "let req = JSON.parse(pm.request.body.raw);",
                  "pm.environment.set(\"loginUsername\", req.username);",
                  "pm.environment.set(\"loginEmail\", req.email);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"user{{$timestamp}}@gmail.com\",\"username\":\"user_{{$timestamp}}\",\"password\":\"123456\",\"fullName\":\"Người Dùng Test\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
