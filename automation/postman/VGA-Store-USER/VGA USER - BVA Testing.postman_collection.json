    {
      "name": "User Addresses",
      "item": [
        {
          "name": "BVA - Add Address (Data-Driven từ CSV)",
          "event": [
            {
              "listen": "pre-request",
              "script": {
                "exec": [
                  "console.log('Test Case: ' + pm.environment.get('TC_ID'));",
                  "console.log('Input recipientName: ' + pm.environment.get('recipientName'));",
                  "console.log('Input phone: ' + pm.environment.get('phone'));",
                  "console.log('Input detailedAddress: ' + pm.environment.get('detailedAddress'));",
                  "console.log('Expected Status: ' + pm.environment.get('expectedStatus'));",
                  "",
                  "let isDefaultStr = pm.environment.get('isDefault') || 'false';",
                  "let isDefaultBool = (isDefaultStr === 'true' || isDefaultStr === true);",
                  "pm.environment.set('isDefaultBool', isDefaultBool);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let expectedStatus = parseInt(pm.environment.get('expectedStatus')) || 200;",
                  "let testId = pm.environment.get('TC_ID');",
                  "let description = pm.environment.get('description');",
                  "let actualStatus = pm.response.code;",
                  "",
                  "pm.test('[' + testId + '] Status code là ' + expectedStatus, function () {",
                  "    pm.response.to.have.status(expectedStatus);",
                  "});",
                  "",
                  "if(expectedStatus === 200) {",
                  "    pm.test('[' + testId + '] Response có success flag', function() {",
                  "        let res = pm.response.json();",
                  "        pm.expect(res).to.have.property('success').equal(true);",
                  "        pm.expect(res.data).to.have.property('addresses');",
                  "    });",
                  "",
                  "    let res = pm.response.json();",
                  "    if(res.data?.addresses && res.data.addresses.length > 0) {",
                  "        let lastAddr = res.data.addresses[res.data.addresses.length - 1];",
                  "        pm.environment.set('addressId', lastAddr.id);",
                  "    }",
                  "}",
                  "",
                  "if(expectedStatus === 400) {",
                  "    pm.test('[' + testId + '] Response chứa error message', function() {",
                  "        let res = pm.response.json();",
                  "        pm.expect(res).to.have.property('success').equal(false);",
                  "    });",
                  "}",
                  "",
                  "if(actualStatus === expectedStatus) {",
                  "    console.log('✓ ' + testId + ' PASS - ' + description);",
                  "} else {",
                  "    console.log('✗ ' + testId + ' FAIL - Expected: ' + expectedStatus + ', Got: ' + actualStatus);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
