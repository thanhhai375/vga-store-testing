  "item": [
    {
      "name": "Authentication (Chạy trước)",
      "item": [
        {
          "name": "TC_SETUP_01 - Register Account",
          "event": [
            {
              "listen": "pre-request",
              "script": {
                "exec": [
                  "pm.environment.set('signupUsername', 'testuser_' + Date.now());",
                  "pm.environment.set('signupEmail', 'testuser_' + Date.now() + '@testmail.com');",
                  "pm.environment.set('signupPassword', 'Test@123456');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[SETUP] Register thành công', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "let res = pm.response.json();",
                  "pm.test('[SETUP] Response có chứa user info', function() {",
                  "    pm.expect(res).to.have.property('success').equal(true);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"email\\\": \\\"{{signupEmail}}\\\",\\n  \\\"username\\\": \\\"{{signupUsername}}\\\",\\n  \\\"password\\\": \\\"{{signupPassword}}\\\",\\n  \\\"fullName\\\": \\\"Test User BVA\\\"\\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "TC_SETUP_02 - Login Account (Lấy Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[SETUP] Login thành công', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "let res = pm.response.json();",
                  "",
                  "let token = res.data?.accessToken || res.data?.token || res.token;",
                  "let userId = res.data?.user?.id || res.data?.id;",
                  "",
                  "pm.test('[SETUP] Response có chứa accessToken', function() {",
                  "    pm.expect(token).to.exist;",
                  "});",
                  "",
                  "if(token) {",
                  "    pm.environment.set('token', token);",
                  "    pm.environment.set('userId', userId);",
                  "    console.log('✓ Token saved: ' + token.substring(0, 20) + '...');",
                  "    console.log('✓ UserId saved: ' + userId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"username\\\": \\\"{{signupUsername}}\\\",\\n  \\\"password\\\": \\\"{{signupPassword}}\\\"\\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
      ],
      "description": "Các request chuẩn bị: Login/Register để lấy token"
    },
