        {
          "name": "BVA - Update Profile (Data-Driven từ CSV)",
          "event": [
            {
              "listen": "pre-request",
              "script": {
                "exec": [
                  "console.log('Test Case: ' + pm.environment.get('TC_ID'));",
                  "console.log('Input fullName: ' + pm.environment.get('fullName'));",
                  "console.log('Input phone: ' + pm.environment.get('phone'));",
                  "console.log('Input dob: ' + pm.environment.get('dob'));",
                  "console.log('Expected Status: ' + pm.environment.get('expectedStatus'));"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let expectedStatus = parseInt(pm.environment.get('expectedStatus')) || 200;",
                  "let testId = pm.environment.get('TC_ID');",
                  "let description = pm.environment.get('description');",
                  "let actualStatus = pm.response.code;",
                  "",
                  "pm.test('[' + testId + '] Status code là ' + expectedStatus, function () {",
                  "    pm.response.to.have.status(expectedStatus);",
                  "});",
                  "",
                  "if(expectedStatus === 200) {",
                  "    pm.test('[' + testId + '] Response có success flag', function() {",
                  "        let res = pm.response.json();",
                  "        pm.expect(res).to.have.property('success').equal(true);",
                  "        pm.expect(res.data).to.have.property('id');",
                  "    });",
                  "}",
                  "",
                  "if(actualStatus === expectedStatus) {",
                  "    console.log('✓ ' + testId + ' PASS - ' + description);",
                  "} else {",
                  "    console.log('✗ ' + testId + ' FAIL - Expected: ' + expectedStatus + ', Got: ' + actualStatus);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
