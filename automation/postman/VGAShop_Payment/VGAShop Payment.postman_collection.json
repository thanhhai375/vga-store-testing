              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const setupId = \"SETUP-LOGIN-USER\";",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "",
                  "pm.test(`${setupId}: Status code is 200`, function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const token = json?.token || json?.accessToken || json?.data?.token || json?.data?.accessToken;",
                  "",
                  "pm.test(`${setupId}: Response contains token`, function () {",
                  "    pm.expect(token).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "if (token) {",
                  "    pm.collectionVariables.set(\"token\", token);",
                  "    pm.environment.set(\"token\", token);",
                  "}"
                ]
              }
            }
          ]
