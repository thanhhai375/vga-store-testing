      "name": "00_Setup",
      "description": "Request hỗ trợ tạo tài khoản, đăng nhập và tạo dữ liệu đơn hàng. Không tính vào 17 test case Payment chính.",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/auth/register",
            "description": "Tạo tài khoản mới duy nhất cho mỗi lần chạy Newman.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{loginUsername}}\",\n  \"email\": \"{{loginEmail}}\",\n  \"password\": \"{{loginPassword}}\",\n  \"fullName\": \"{{loginFullName}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const now = Date.now();",
                  "const shouldGenerate = String(pm.variables.get(\"generateNewUser\") ?? \"true\").toLowerCase() === \"true\";",
                  "",
                  "if (shouldGenerate) {",
                  "    const username = `kcpm92_${now}`;",
                  "    const email = `kcpm92_${now}@test.local`;",
                  "    const password = pm.variables.get(\"loginPassword\") || \"Kcpm@12345\";",
                  "    pm.collectionVariables.set(\"loginUsername\", username);",
                  "    pm.collectionVariables.set(\"loginEmail\", email);",
                  "    pm.collectionVariables.set(\"loginPassword\", password);",
                  "    pm.collectionVariables.set(\"loginFullName\", \"KCPM 92 Test User\");",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const setupId = \"SETUP-REGISTER\";",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "",
                  "pm.test(`${setupId}: Status code is 200`, function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(`${setupId}: Registration returns a user response`, function () {",
                  "    pm.expect(json).to.be.an('object');",
                  "});"
                ]
              }
            }
          ]
        },
