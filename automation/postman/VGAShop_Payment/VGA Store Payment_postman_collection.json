    {
      "name": "Create Order",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "function parseJsonSafely() {",
              "    try { return pm.response.json(); } catch (error) { return {}; }",
              "}",
              "",
              "var testId = pm.iterationData.get(\"testId\");",
              "var expectedStatus = Number(pm.iterationData.get(\"expectedStatus\"));",
              "var expectedMessage = String(pm.iterationData.get(\"expectedMessage\") || \"\").toLowerCase();",
              "var responseText = pm.response.text().toLowerCase();",
              "var jsonData = parseJsonSafely();",
              "",
              "pm.test(testId + \": Expected HTTP status \" + expectedStatus, function () {",
              "    pm.expect(pm.response.code).to.eql(expectedStatus);",
              "});",
              "",
              "if (expectedMessage) {",
              "    pm.test(testId + \": Response contains expected message\", function () {",
              "        pm.expect(responseText).to.include(expectedMessage);",
              "    });",
              "}",
              "",
              "if (expectedStatus >= 200 && expectedStatus < 300) {",
              "    pm.test(testId + \": Response contains orderId\", function () {",
              "        var orderId = jsonData.orderId || (jsonData.data && jsonData.data.orderId);",
              "        pm.expect(orderId, \"orderId\").to.exist;",
              "        pm.collectionVariables.set(\"runtimeOrderId\", String(orderId));",
              "    });",
              "}",
              "",
              "console.log(\"ORDER_CREATE \" + testId + \" completed with status \" + pm.response.code);"
            ]
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "var testType = pm.iterationData.get(\"testType\");",
              "var testId = pm.iterationData.get(\"testId\");",
              "",
              "if (testType !== \"ORDER_CREATE\") {",
              "    pm.execution.skipRequest();",
              "}",
              "",
              "function parseItems(raw) {",
              "    try {",
              "        return JSON.parse(raw || \"[]\");",
              "    } catch (error) {",
              "        throw new Error(testId + \": itemsJson không phải JSON hợp lệ\");",
              "    }",
              "}",
              "",
              "var body = {",
              "    fullName: pm.iterationData.get(\"fullName\") || \"\",",
              "    phone: (function () { var value = pm.iterationData.get(\"phone\"); var text = value === undefined || value === null ? \"\" : String(value); return text && !text.startsWith(\"0\") ? \"0\" + text : text; })(),",
              "    shippingAddress: pm.iterationData.get(\"shippingAddress\") || \"\",",
              "    address: pm.iterationData.get(\"address\") || \"\",",
              "    note: pm.iterationData.get(\"note\") || \"\",",
              "    items: parseItems(pm.iterationData.get(\"itemsJson\"))",
              "};",
              "",
              "var omitFields = String(pm.iterationData.get(\"omitFields\") || \"\")",
              "    .split(\"|\")",
              "    .map(function (field) { return field.trim(); })",
              "    .filter(Boolean);",
              "",
              "omitFields.forEach(function (field) {",
              "    delete body[field];",
              "});",
              "",
              "pm.request.body.raw = JSON.stringify(body);",
              "console.log(\"ORDER_CREATE \" + testId + \" body:\", pm.request.body.raw);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
