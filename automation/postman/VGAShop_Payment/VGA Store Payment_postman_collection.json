        },
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "var testType = pm.iterationData.get(\"testType\");",
              "var testId = pm.iterationData.get(\"testId\");",
              "var setupOrder = String(pm.iterationData.get(\"setupOrder\") || \"false\").toLowerCase() === \"true\";",
              "",
              "if (!setupOrder || (testType !== \"PAYMENT_CREATE\" && testType !== \"ORDER_STATUS\")) {",
              "    pm.execution.skipRequest();",
              "}",
              "",
              "var items = [];",
              "try {",
              "    items = JSON.parse(pm.iterationData.get(\"itemsJson\") || \"[]\");",
              "} catch (error) {",
              "    throw new Error(testId + \": itemsJson không phải JSON hợp lệ\");",
              "}",
              "",
              "var body = {",
              "    fullName: pm.iterationData.get(\"fullName\") || \"\",",
              "    phone: (function () { var value = pm.iterationData.get(\"phone\"); var text = value === undefined || value === null ? \"\" : String(value); return text && !text.startsWith(\"0\") ? \"0\" + text : text; })(),",
              "    shippingAddress: pm.iterationData.get(\"shippingAddress\") || \"\",",
              "    address: pm.iterationData.get(\"address\") || \"\",",
              "    note: pm.iterationData.get(\"note\") || \"\",",
              "    items: items",
              "};",
              "",
              "pm.request.body.raw = JSON.stringify(body);",
              "console.log(\"SETUP_ORDER \" + testId + \" body:\", pm.request.body.raw);"
            ]
          }
        }
      ],
