    {
      "name": "Create Payment",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "function parseJsonSafely() {",
              "    try { return pm.response.json(); } catch (error) { return {}; }",
              "}",
              "",
              "var testId = pm.iterationData.get(\"testId\");",
              "var expectedStatus = Number(pm.iterationData.get(\"expectedStatus\"));",
              "var expectedMessage = String(pm.iterationData.get(\"expectedMessage\") || \"\").toLowerCase();",
              "var expectedSuccessRaw = pm.iterationData.get(\"expectedSuccess\");",
              "var expectedPaymentStatus = pm.iterationData.get(\"expectedPaymentStatus\");",
              "var expectedPaymentMethod = pm.iterationData.get(\"paymentMethod\");",
              "var responseText = pm.response.text().toLowerCase();",
              "var jsonData = parseJsonSafely();",
              "",
              "pm.test(testId + \": Expected HTTP status \" + expectedStatus, function () {",
              "    pm.expect(pm.response.code).to.eql(expectedStatus);",
              "});",
              "",
              "if (expectedMessage) {",
              "    pm.test(testId + \": Response contains expected message\", function () {",
              "        pm.expect(responseText).to.include(expectedMessage);",
              "    });",
              "}",
              "",
              "if (expectedSuccessRaw !== null && expectedSuccessRaw !== undefined && expectedSuccessRaw !== \"\") {",
              "    var expectedSuccess = String(expectedSuccessRaw).toLowerCase() === \"true\";",
              "    if (Object.prototype.hasOwnProperty.call(jsonData, \"success\")) {",
              "        pm.test(testId + \": Expected success value\", function () {",
              "            pm.expect(jsonData.success).to.eql(expectedSuccess);",
              "        });",
              "    }",
              "}",
              "",
              "if (expectedStatus >= 200 && expectedStatus < 300) {",
              "    pm.test(testId + \": Response contains payment data\", function () {",
              "        pm.expect(jsonData.data, \"data\").to.be.an(\"object\");",
              "        pm.expect(jsonData.data.paymentId, \"paymentId\").to.exist;",
              "        pm.expect(jsonData.data.orderId, \"orderId\").to.exist;",
              "    });",
              "",
              "    if (expectedPaymentMethod) {",
              "        pm.test(testId + \": Payment method is correct\", function () {",
              "            pm.expect(jsonData.data && jsonData.data.paymentMethod).to.eql(expectedPaymentMethod);",
              "        });",
              "    }",
              "",
              "    if (expectedPaymentStatus) {",
              "        pm.test(testId + \": Payment status is correct\", function () {",
              "            pm.expect(jsonData.data && jsonData.data.paymentStatus).to.eql(expectedPaymentStatus);",
              "        });",
              "    }",
              "}",
              "",
              "console.log(\"PAYMENT_CREATE \" + testId + \" completed with status \" + pm.response.code);"
            ]
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "var testType = pm.iterationData.get(\"testType\");",
              "var testId = pm.iterationData.get(\"testId\");",
              "",
              "if (testType !== \"PAYMENT_CREATE\") {",
              "    pm.execution.skipRequest();",
              "}",
              "",
              "var setupOrder = String(pm.iterationData.get(\"setupOrder\") || \"false\").toLowerCase() === \"true\";",
              "",
              "if (!setupOrder) {",
              "    pm.collectionVariables.set(\"runtimeOrderId\", String(pm.iterationData.get(\"orderId\") || \"\"));",
              "}",
              "",
              "var paymentBody = {",
              "    paymentMethod: pm.iterationData.get(\"paymentMethod\") || \"\"",
              "};",
              "",
              "var omitFields = String(pm.iterationData.get(\"omitFields\") || \"\")",
              "    .split(\"|\")",
              "    .map(function (field) { return field.trim(); })",
              "    .filter(Boolean);",
              "",
              "omitFields.forEach(function (field) {",
              "    delete paymentBody[field];",
              "});",
              "",
              "pm.request.body.raw = JSON.stringify(paymentBody);",
              "console.log(\"PAYMENT_CREATE \" + testId + \" orderId:\", pm.collectionVariables.get(\"runtimeOrderId\"));",
              "console.log(\"PAYMENT_CREATE \" + testId + \" body:\", pm.request.body.raw);"
            ]
          }
        }
