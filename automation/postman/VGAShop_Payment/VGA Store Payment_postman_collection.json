      "name": "Setup Auth - Register",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "if (pm.info.iteration !== 0) { return; }",
              "",
              "pm.test(\"AUTH_SETUP: Register test user returns 200 or 201\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});"
            ]
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "if (pm.info.iteration !== 0) {",
              "    pm.execution.skipRequest();",
              "}",
              "",
              "var suffix = Date.now().toString(36);",
              "var username = \"payment_ci_\" + suffix;",
              "var email = \"payment_ci_\" + suffix + \"@test.com\";",
              "var password = \"123456\";",
              "",
              "pm.collectionVariables.set(\"ciUsername\", username);",
              "pm.collectionVariables.set(\"ciEmail\", email);",
              "pm.collectionVariables.set(\"ciPassword\", password);",
              "",
              "pm.request.body.raw = JSON.stringify({",
              "    username: username,",
              "    email: email,",
              "    password: password,",
              "    fullName: \"Payment CI User\"",
              "});",
              "",
              "console.log(\"AUTH_SETUP register user:\", username);"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
