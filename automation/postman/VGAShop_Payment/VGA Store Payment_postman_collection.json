    {
      "name": "Setup Auth - Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "if (pm.info.iteration !== 0) { return; }",
              "",
              "var jsonData = {};",
              "try { jsonData = pm.response.json(); } catch (error) {}",
              "",
              "var token = jsonData.token || (jsonData.data && jsonData.data.token);",
              "",
              "pm.test(\"AUTH_SETUP: Login returns 200\", function () {",
              "    pm.expect(pm.response.code).to.eql(200);",
              "});",
              "",
              "pm.test(\"AUTH_SETUP: Login response contains token\", function () {",
              "    pm.expect(token, \"token\").to.exist;",
              "});",
              "",
              "if (token) {",
              "    pm.environment.set(\"authToken\", token);",
              "    pm.environment.set(\"token\", token);",
              "    pm.collectionVariables.set(\"authToken\", token);",
              "}"
            ]
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "if (pm.info.iteration !== 0) {",
