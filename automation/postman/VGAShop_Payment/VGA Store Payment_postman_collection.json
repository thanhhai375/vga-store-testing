              "if (orderId !== undefined && orderId !== null) {",
              "    pm.collectionVariables.set(\"runtimeOrderId\", String(orderId));",
              "}",
              "",
              "console.log(\"SETUP_ORDER \" + testId + \" saved orderId:\", orderId);"
            ]
