                  "    // Trường hợp 1: ID nằm trong resBody.data",
                  "    if (resBody && resBody.data) {",
                  "        paymentId = resBody.data.paymentId || resBody.data.id;",
                  "    } ",
                  "    // Trường hợp 2: ID nằm ngay lớp ngoài cùng của resBody",
                  "    else if (resBody) {",
                  "        paymentId = resBody.paymentId || resBody.id;",
                  "    }",
                  "",
                  "    // Nếu tìm thấy ID thì tiến hành lưu vào biến môi trường",
                  "    if (paymentId) {",
                  "        pm.environment.set(\"codPaymentId\", paymentId);",
                  "        console.log(\"🎯 Đã lưu tự động codPaymentId thành công:\", paymentId);",
                  "    } else {",
