          "name": "Create Payment - BANK_TRANSFER",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "packages": {},
                "requests": {},
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const responseData = pm.response.json();",
                  "    ",
                  "    // Khai báo 2 biến tạm để hứng dữ liệu",
                  "    let pId = null;",
                  "    let tCode = null;",
                  "",
                  "    if (responseData) {",
                  "        // Trường hợp 1: Dữ liệu bọc trong object 'data'",
                  "        if (responseData.data) {",
                  "            pId = responseData.data.paymentId || responseData.data.id;",
                  "            tCode = responseData.data.transactionCode || responseData.data.vnp_TxnRef || responseData.data.orderId;",
                  "        } ",
                  "        // Trường hợp 2: Dữ liệu nằm tuột ra lớp ngoài cùng",
                  "        else {",
                  "            pId = responseData.paymentId || responseData.id;",
                  "            tCode = responseData.transactionCode || responseData.orderId;",
                  "        }",
                  "    }",
                  "",
                  "    // Tiến hành lưu vào biến môi trường nếu tìm thấy dữ liệu hợp lệ",
                  "    if (pId) {",
                  "        pm.environment.set(\"bankPaymentId\", pId);",
                  "        console.log(\"🎯 [SUCCESS] Đã lưu bankPaymentId:\", pId);",
                  "    } else {",
                  "        console.error(\"❌ [ERROR] Không trích xuất được ID thanh toán (id/paymentId) từ Response.\");",
                  "    }",
                  "",
                  "    if (tCode) {",
                  "        pm.environment.set(\"bankTransactionCode\", tCode);",
                  "        console.log(\"🎯 [SUCCESS] Đã lưu bankTransactionCode:\", tCode);",
                  "    } else {",
                  "        console.warn(\"⚠️ [WARN] Không tìm thấy mã giao dịch (transactionCode) trong Response.\");",
                  "    }",
                  "",
