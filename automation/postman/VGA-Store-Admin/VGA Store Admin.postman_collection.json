      "item": [
        {
          "name": "TC_ADM_AUTH_01 - Đăng ký Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"TC_ADM_AUTH_01 - Status code là 200 hoặc 201\", function () { pm.expect(pm.response.code).to.be.oneOf([200, 201, 400]); });",
                  "let res = pm.response.json();",
                  "if(res.data && res.data.username) pm.environment.set(\"adminUsername\", res.data.username);",
                  "else if (!pm.environment.get(\"adminUsername\")) pm.environment.set(\"adminUsername\", \"admin_test_1\");"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"admin_test_{{$timestamp}}\",\"password\":\"123456\",\"email\":\"admin{{$timestamp}}@gmail.com\",\"fullName\":\"Super Admin\",\"role\":\"ADMIN\"}"
            },
            "url": {
