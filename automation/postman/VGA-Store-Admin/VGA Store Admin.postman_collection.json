                "exec": [
                  "pm.test(\"TC_ADM_AUTH_02 - Status code là 200\", function () { pm.response.to.have.status(200); });",
                  "let res = pm.response.json();",
                  "if(res.token) pm.environment.set(\"adminToken\", res.token);",
                  "else if(res.data && res.data.token) pm.environment.set(\"adminToken\", res.data.token);"
